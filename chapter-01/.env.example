# Copy this file to .env and fill in the values for local development.
# These variables are set automatically when you run `azd up`.

# Azure AI Project endpoint (from `azd env get-values | grep AZURE_AI_PROJECT_ENDPOINT`)
AZURE_AI_PROJECT_ENDPOINT=

# Azure AI Search connection resource-id (from the AI Hub connections blade)
AZURE_AI_SEARCH_CONNECTION_ID=

# Name of the search index (default: documents)
AZURE_AI_SEARCH_INDEX_NAME=documents

# (Optional) Override the agent name used by chat.py
# AGENT_NAME=foundry-qa-agent
