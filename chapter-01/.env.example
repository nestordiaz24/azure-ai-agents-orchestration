# Copy this file to .env and fill in the values for local development.
# These variables are set automatically when you run `azd up`.

# Azure AI Foundry project endpoint
# (from `azd env get-values | grep AZURE_AI_PROJECT_ENDPOINT`)
AZURE_AI_PROJECT_ENDPOINT=

# Azure OpenAI model deployment name (default: gpt-4o)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# (Optional) Override the agent name used by chat.py
# AGENT_NAME=foundry-qa-agent
