# ── Azure AI Foundry / Agent SDK ────────────────────────────────────────────
# Azure AI Foundry project endpoint.
# Format: https://<project-name>.services.ai.azure.com/api/projects/<project-id>
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
# The model *deployment* name inside your AI Services resource.
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# API key (optional – DefaultAzureCredential is preferred; set this for key auth)
AZURE_OPENAI_API_KEY=

# ── Agent configuration ───────────────────────────────────────────────────────
# Name used when creating/looking up the agent in your Foundry project.
AGENT_NAME=product-recommendation-agent

# ── Product catalog ───────────────────────────────────────────────────────────
# Absolute or relative path to the products JSON file.
# Defaults to data/products.json (relative to the chapter-02 directory).
PRODUCTS_JSON_PATH=

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
